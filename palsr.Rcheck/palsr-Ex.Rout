2   G02 2010-12-01  8.073719  7.316780      45     182        TRUE
3   G03 2010-12-01  8.958631  9.924148      21     187        TRUE
4   G04 2010-12-01 10.502588  6.782979       4     130        TRUE
5   G05 2010-12-01  7.655026 11.563868      42     186        TRUE
6   G06 2010-12-01 12.392800  8.977235      32     163        TRUE
